# ─── Google Cloud / Gemini ────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here

# ─── LlamaParse (optional — falls back to PyMuPDF if not set) ─────────────────
LLAMA_PARSE_API_KEY=your_llama_parse_api_key_here

# ─── Qdrant Vector Database ───────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                          # leave blank for local Docker Qdrant
QDRANT_COLLECTION_NAME=gov_policies

# ─── Local LLM via Ollama (optional) ─────────────────────────────────────────
USE_LOCAL_LLM=false
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3:8b-instruct-q4_K_M

# ─── Embedding Mode ───────────────────────────────────────────────────────────
# false = use local BAAI/bge-m3 (downloads ~2.5 GB on first run)
# true  = use Gemini Embedding API (requires GOOGLE_API_KEY)
USE_CLOUD_EMBEDDINGS=false
EMBEDDING_MODEL=BAAI/bge-m3
SPARSE_MODEL=prithivida/Splade_PP_en_v1

# ─── Reranker ─────────────────────────────────────────────────────────────────
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ─── Cloud Gemini Models ──────────────────────────────────────────────────────
GEMINI_LLM_MODEL=models/gemini-2.5-flash
GEMINI_VISION_MODEL=models/gemini-2.5-flash

# ─── ETL / Ingestion ─────────────────────────────────────────────────────────
DATA_DIR=./data
SCRAPED_DIR=./data/scraped
POLICIES_DIR=./data/policies

# ─── Scraper Schedule (cron syntax) ──────────────────────────────────────────
SCRAPER_CRON_HOUR=2
SCRAPER_CRON_MINUTE=0
